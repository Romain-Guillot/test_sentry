# Fastlane Match Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Apple Developer Team IDs
DEVELOPER_PORTAL_TEAM_ID="YOUR_TEAM_ID"
APP_STORE_CONNECT_TEAM_ID="YOUR_TEAM_ID"

# App Store Connect API Key (required for SSO-enabled accounts and write lanes)
# Generate at: https://appstoreconnect.apple.com/ > Users and Access > Integrations > Keys
# Download the .p8 file and place it in the fastlane/ directory
APP_STORE_CONNECT_KEY_ID="YOUR_KEY_ID"           # e.g., "ABC123XYZ4"
APP_STORE_CONNECT_ISSUER_ID="YOUR_ISSUER_ID"    # e.g., "12345678-1234-1234-1234-123456789012"
APP_STORE_CONNECT_KEY_PATH="./fastlane/AuthKey_YOUR_KEY_ID.p8"

# Match Git Repository (private repo storing encrypted certs/profiles)
MATCH_GIT_URL="git@github.com:your-org/ios-certificates.git"
MATCH_PASSWORD="your-strong-password-for-encrypting-certificates"

# Match Git Branch (for multi-team workflows)
MATCH_GIT_BRANCH="main"

# Optional: HTTPS auth for CI (base64 of "username:token")
# MATCH_GIT_BASIC_AUTHORIZATION=""
